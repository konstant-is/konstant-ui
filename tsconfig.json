{
    "compilerOptions": {
      "baseUrl": "./",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "node", // Instead of "node16" or "nodenext"
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "target": "ES2022",
      "plugins": [
        {
          "name": "next"
        }
      ],
      "paths": {
        "@/*": [
          "./src/*"
        ],
      }
    },
    "include": ["./src/**/*.ts", "./src/**/*.tsx", "./dev/next-env.d.ts", "./types.d.ts", ],
    "exclude": [
      "node_modules"
    ]
  }
  